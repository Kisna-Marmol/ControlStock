<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_gris">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@color/azul_principal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp">

        <ImageView
            android:id="@+id/btnVolver"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ct_arrow_back"
            android:tint="@color/blanco"
            android:padding="8dp"
            android:contentDescription="Volver"/>

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Nuevo Movimiento"
            android:textColor="@color/blanco"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="70dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <!-- TIPO DE MOVIMIENTO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de movimiento"
                        android:textColor="@color/texto_oscuro"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <!-- Botón ENTRADA -->
                        <LinearLayout
                            android:id="@+id/btnEntrada"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/bg_btn_tipo_selected"
                            android:padding="8dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ct_trending_up"
                                android:tint="@color/blanco"
                                android:contentDescription="Entrada"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Entrada"
                                android:textColor="@color/blanco"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>

                        <!-- Botón SALIDA -->
                        <LinearLayout
                            android:id="@+id/btnSalida"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/bg_btn_tipo_unselected"
                            android:padding="8dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ct_trending_up"
                                android:tint="@color/texto_secundario"
                                android:rotation="180"
                                android:contentDescription="Salida"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Salida"
                                android:textColor="@color/texto_secundario"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SELECCIONAR PRODUCTO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Producto *"
                        android:textColor="@color/texto_secundario"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/fondo_gris">

                        <Spinner
                            android:id="@+id/spinnerProducto"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Stock actual -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stock actual: "
                            android:textColor="@color/texto_secundario"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/tvStockActual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/azul_principal"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CANTIDAD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cantidad *"
                        android:textColor="@color/texto_secundario"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/fondo_gris">

                        <EditText
                            android:id="@+id/etCantidad"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="0"
                            android:textColorHint="@color/gris_icono"
                            android:textColor="@color/texto_oscuro"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@null"
                            android:inputType="number"/>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BOTÓN REGISTRAR -->
            <Button
                android:id="@+id/btnRegistrar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Registrar movimiento"
                android:textColor="@color/blanco"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_guardar"
                app:backgroundTint="@null"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>