<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1E3A8A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ct_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nueva Venta"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingStart="8dp" />

        <TextView
            android:id="@+id/tvNumeroFactura"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#0001"
            android:textColor="#93C5FD"
            android:textSize="13sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- CARD CLIENTE -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cliente *"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etBuscarCliente"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:hint="Buscar cliente..."
                            android:textSize="14sp"
                            android:background="@drawable/bg_input"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:inputType="text"
                            android:imeOptions="actionSearch"
                            android:maxLines="1" />

                        <Button
                            android:id="@+id/btnBuscarCliente"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Buscar"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#3B82F6"
                            android:layout_marginStart="8dp"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Resultado cliente seleccionado -->
                    <LinearLayout
                        android:id="@+id/layoutClienteSeleccionado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#EFF6FF"
                        android:padding="8dp"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ct_person"
                            android:tint="#3B82F6" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="8dp">

                            <TextView
                                android:id="@+id/tvClienteNombre"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#1F2937"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvClienteDoc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#6B7280"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/btnQuitarCliente"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ct_close"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:tint="#EF4444" />
                    </LinearLayout>

                    <!-- ListView búsqueda clientes -->
                    <ListView
                        android:id="@+id/lvBusquedaClientes"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:visibility="gone"
                        android:divider="#E5E7EB"
                        android:dividerHeight="1dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD AGREGAR PRODUCTO -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agregar Producto"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etBuscarProducto"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:hint="Buscar producto..."
                            android:textSize="14sp"
                            android:background="@drawable/bg_input"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:inputType="text"
                            android:imeOptions="actionSearch"
                            android:maxLines="1" />

                        <Button
                            android:id="@+id/btnBuscarProducto"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Buscar"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#3B82F6"
                            android:layout_marginStart="8dp"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- ListView búsqueda productos -->
                    <ListView
                        android:id="@+id/lvBusquedaProductos"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:visibility="gone"
                        android:divider="#E5E7EB"
                        android:dividerHeight="1dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD CARRITO -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Carrito"
                            android:textColor="#1E3A8A"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCantidadItems"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 items"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ListView
                        android:id="@+id/lvCarrito"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:divider="#E5E7EB"
                        android:dividerHeight="1dp" />

                    <TextView
                        android:id="@+id/tvCarritoVacio"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="No hay productos agregados"
                        android:textColor="#9CA3AF"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:visibility="visible" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD TOTALES -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resumen"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingBottom="8dp" />

                    <!-- Subtotal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Subtotal:"
                            android:textColor="#6B7280"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvSubtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="L. 0.00"
                            android:textColor="#1F2937"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Impuesto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Impuesto (15%):"
                            android:textColor="#6B7280"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvImpuesto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="L. 0.00"
                            android:textColor="#1F2937"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Divisor -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E5E7EB"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />

                    <!-- Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOTAL:"
                            android:textColor="#1E3A8A"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="L. 0.00"
                            android:textColor="#10B981"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTÓN GUARDAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnGuardarVenta"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="GUARDAR VENTA"
            android:textColor="#FFFFFF"
            android:backgroundTint="#10B981"
            android:textStyle="bold"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>