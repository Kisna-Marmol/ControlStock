<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_gris"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/azul_principal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="40dp">

            <ImageView
                android:id="@+id/btnVolver"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ct_arrow_back"
                android:tint="@color/blanco"
                android:padding="8dp"
                android:contentDescription="Volver"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Configuración"
                android:textColor="@color/blanco"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </RelativeLayout>

        <!-- PERFIL DEL USUARIO -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/blanco">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <!-- Avatar -->
                <androidx.cardview.widget.CardView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/azul_principal">

                    <TextView
                        android:id="@+id/tvInicialUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="K"
                        android:textColor="@color/blanco"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                </androidx.cardview.widget.CardView>

                <!-- Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:id="@+id/tvNombreUsuario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre Usuario"
                        android:textColor="@color/texto_oscuro"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvRolUsuario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rol"
                        android:textColor="@color/azul_claro"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tvCorreoUsuario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="correo@email.com"
                        android:textColor="@color/texto_secundario"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SECCIÓN ADMIN — solo visible para administrador -->
        <LinearLayout
            android:id="@+id/layoutSeccionAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Administración"
                android:textColor="@color/texto_secundario"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Bitácora -->
                    <LinearLayout
                        android:id="@+id/btnBitacora"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ct_schedule"
                            android:tint="@color/azul_claro"
                            android:contentDescription="Bitácora"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bitácora del sistema"
                            android:textColor="@color/texto_oscuro"
                            android:textSize="15sp"
                            android:paddingStart="14dp"/>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ct_arrow_back"
                            android:rotation="180"
                            android:tint="@color/gris_icono"
                            android:contentDescription="Ir"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="54dp"
                        android:background="@color/gris_icono"
                        android:alpha="0.3"/>

                    <!-- Control de accesos -->
                    <LinearLayout
                        android:id="@+id/btnControlAccesos"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ct_lock"
                            android:tint="@color/azul_claro"
                            android:contentDescription="Accesos"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Control de accesos"
                            android:textColor="@color/texto_oscuro"
                            android:textSize="15sp"
                            android:paddingStart="14dp"/>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ct_arrow_back"
                            android:rotation="180"
                            android:tint="@color/gris_icono"
                            android:contentDescription="Ir"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="54dp"
                        android:background="@color/gris_icono"
                        android:alpha="0.3"/>

                    <!-- Gestión de usuarios -->
                    <LinearLayout
                        android:id="@+id/btnUsuarios"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ct_group"
                            android:tint="@color/azul_claro"
                            android:contentDescription="Usuarios"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Gestión de usuarios"
                            android:textColor="@color/texto_oscuro"
                            android:textSize="15sp"
                            android:paddingStart="14dp"/>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ct_arrow_back"
                            android:rotation="180"
                            android:tint="@color/gris_icono"
                            android:contentDescription="Ir"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="54dp"
                        android:background="@color/gris_icono"
                        android:alpha="0.3"/>

                    <!-- Catálogos -->
                    <LinearLayout
                        android:id="@+id/btnCatalogos"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ct_bar_chart"
                            android:tint="@color/azul_claro"
                            android:contentDescription="Catálogos"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Catálogos"
                            android:textColor="@color/texto_oscuro"
                            android:textSize="15sp"
                            android:paddingStart="14dp"/>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ct_arrow_back"
                            android:rotation="180"
                            android:tint="@color/gris_icono"
                            android:contentDescription="Ir"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- SECCIÓN GENERAL — visible para todos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="General"
                android:textColor="@color/texto_secundario"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Movimientos -->
                    <LinearLayout
                        android:id="@+id/btnMovimientos"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ct_trending_up"
                            android:tint="@color/verde_acento"
                            android:contentDescription="Movimientos"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Movimientos de inventario"
                            android:textColor="@color/texto_oscuro"
                            android:textSize="15sp"
                            android:paddingStart="14dp"/>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ct_arrow_back"
                            android:rotation="180"
                            android:tint="@color/gris_icono"
                            android:contentDescription="Ir"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="54dp"
                        android:background="@color/gris_icono"
                        android:alpha="0.3"/>

                    <!-- Perfil -->
                    <LinearLayout
                        android:id="@+id/btnPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ct_person"
                            android:tint="@color/verde_acento"
                            android:contentDescription="Perfil"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mi perfil"
                            android:textColor="@color/texto_oscuro"
                            android:textSize="15sp"
                            android:paddingStart="14dp"/>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ct_arrow_back"
                            android:rotation="180"
                            android:tint="@color/gris_icono"
                            android:contentDescription="Ir"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- CERRAR SESIÓN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp">

            <Button
                android:id="@+id/btnCerrarSesion"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Cerrar sesión"
                android:textColor="@color/rojo_negativo"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_outline_rojo"
                app:backgroundTint= "@null"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>